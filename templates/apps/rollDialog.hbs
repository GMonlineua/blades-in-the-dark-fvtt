<div>
  <div class="inputs-block">
    <div class="roll-type">
      <label for="roll-type">{{localize "BITD.Roll.Type.Title"}}: </label>
      <select
        id="roll-type"
        class="optional-listen dice-listen"
        name="rollType"
        data-type="String"
      >
        {{selectOptions
          rollConfig.type
          selected=rollConfig.defaults.type
          localize=true
        }}
      </select>
    </div>

    <div class="general-info">
      <div class="roll-as optional" data-connected="information">
        <label for="roll-as">{{localize "BITD.Roll.GatherInformation.RollAs"}}:
        </label>
        <select
          id="roll-as"
          class="optional-listen dice-listen"
          name="rollAs"
          data-type="String"
        >
          {{selectOptions rollConfig.rollAs selected="action" localize=true}}
        </select>
      </div>

      <div class="attributes optional" data-connected="resistance">
        <label for="attribute">{{localize "BITD.Attributes.Attribute"}}:
        </label>
        <select
          id="attribute"
          class="dice-listen"
          name="attribute"
          data-type="String"
        >
          {{selectOptions
            rollConfig.attributes
            selected=rollConfig.defaults.attribute
            localize=true
          }}
        </select>
      </div>

      <div class="action optional" data-connected="action">
        <label for="action">{{localize "BITD.Actions.Action"}}: </label>
        <select
          id="action"
          class="dice-listen"
          name="action"
          data-type="String"
        >
          {{selectOptions
            rollConfig.actions
            selected=rollConfig.defaults.action
            localize=true
          }}
        </select>
      </div>
    </div>

    <div class="grid-2col roll-dice">
      <div class="dice-number">
        <label for="dice-number">{{localize "BITD.Roll.DiceNumber"}}: </label>
        <input
          id="dice-number"
          name="diceNumber"
          type="number"
          value="{{rollConfig.defaults.dice}}"
          data-dtype="Number"
        />
      </div>

      <div class="optional" data-connected="action,fortune">
        <input
          id="assistance"
          name="assistance"
          type="checkbox"
          data-dtype="Boolean"
        />
        <label class="checkbox-label" for="assistance">{{localize
            "BITD.Roll.Bonus.Assistance"
          }}</label>
      </div>

      <div class="modifier">
        <label for="modifier">{{localize "BITD.Roll.Modifier"}}: </label>
        <input
          id="modifier"
          name="modifier"
          type="number"
          value="0"
          data-dtype="Number"
        />
      </div>

      <div class="optional" data-connected="action,fortune">
        <input
          id="pushEffect"
          name="pushEffect"
          type="checkbox"
          data-dtype="Boolean"
        />
        <label class="checkbox-label" for="pushEffect">{{localize
            "BITD.Roll.Bonus.PushEffect"
          }}</label>
      </div>
    </div>

    <div class="push-or-devil optional" data-connected="action,fortune">
      <h4 for="push-or-dice">{{localize "BITD.Roll.Bonus.AddDice"}}</h4>

      <div>
        <input
          id="pushDice"
          name="pushDice"
          type="checkbox"
          data-dtype="Boolean"
        />
        <label class="checkbox-label" for="pushDice">{{localize
            "BITD.Roll.Bonus.Push"
          }}</label>
      </div>

      <span>{{localize "BITD.Roll.Bonus.or"}}</span>

      <div>
        <input
          id="devisBargain"
          name="devisBargain"
          type="checkbox"
          data-dtype="Boolean"
        />
        <label class="checkbox-label" for="devisBargain">{{localize
            "BITD.Roll.Bonus.DevilsBargain"
          }}</label>
      </div>
    </div>

    <div class="position-and-effect optional" data-connected="action">
      <h4 for="position-and-effect">{{localize "BITD.Roll.PositionEffect"}}</h4>

      <div class="position optional" data-connected="action">
        <label>{{localize "BITD.Roll.Position.Title"}}:</label>
        <select id="position" name="position" data-type="Number">
          {{selectOptions rollConfig.position selected="risky" localize=true}}
        </select>
      </div>

      <div class="effect optional" data-connected="action">
        <label>{{localize "BITD.Roll.Effect.Title"}}:</label>
        <select id="effect" name="effect" data-type="Number">
          {{selectOptions rollConfig.effect selected="standard" localize=true}}
        </select>
      </div>
    </div>

    {{#if harm}}
      <div class="harm optional" data-connected="action">
        <label>{{localize "BITD.Scoundrel.Harms.Harm"}}</label>
        <multi-select id="harm" name="harm" data-type="String">
          {{selectOptions harm}}
        </multi-select>
      </div>
    {{/if}}

    <div class="useful-info">
      <ul class="optional" data-connected="engagement">
        <li>{{{localize "BITD.Roll.Engagement.Operation"}}}</li>
        <li>{{{localize "BITD.Roll.Engagement.Plan"}}}</li>
        <li>{{{localize "BITD.Roll.Engagement.Contact"}}}</li>
        <li>{{{localize "BITD.Roll.Engagement.Other"}}}</li>
      </ul>
    </div>
  </div>

  <div class="roll-summary">
    <hr />
    <h4>{{localize "BITD.Roll.Summary"}}</h4>
    <div class="grid-2col">
      <div class="summary-item">
        <span>{{localize "BITD.Roll.DiceNumber"}}:</span>
        <span id="summary-dice">0</span>
      </div>
      <div class="summary-item">
        <span>{{localize "BITD.Roll.Stress"}}:</span>
        <span id="summary-stress">0</span>
      </div>
      <div class="summary-item optional" data-connected="action">
        <span>{{localize "BITD.Roll.Effect.Title"}}:</span>
        <span id="summary-effect"></span>
      </div>
    </div>
  </div>

  <button type="submit">{{localize "BITD.Roll.Submit"}}</button>
</div>
