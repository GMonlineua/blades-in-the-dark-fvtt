<form class="{{cssClass}} {{actor.type}}" autocomplete="off">
  {{! Sheet Header }}
  <header class="sheet-header actor-grid">

    <img
      class="profile-img"
      src="{{actor.img}}"
      data-edit="img"
      title="{{actor.name}}"
    />

    <div class="header-fields">
      <h1 class="character-name">
        {{#if system.names.useAlias}}
          <input
            class="clear-input"
            name="system.names.alias"
            type="text"
            value="{{system.names.alias}}"
            placeholder="{{localize 'BITD.Actor.Alias'}}"
          />
        {{else}}
          <input
            class="clear-input"
            name="system.names.real"
            type="text"
            value="{{system.names.real}}"
            placeholder="{{localize 'BITD.Actor.HumanName'}}"
          />
        {{/if}}
      </h1>
      <div class="character-aka">
        {{#if system.names.useAlias}}
          <label for="system.names.real">{{localize
              "BITD.Actor.HumanName"
            }}:</label>
          <input
            class="clear-input"
            name="system.names.real"
            type="text"
            value="{{system.names.real}}"
            placeholder="{{localize 'BITD.Actor.HumanName'}}"
          />
        {{else}}
          <label for="system.names.real">{{localize
              "BITD.Actor.Alias"
            }}:</label>
          <input
            class="clear-input"
            name="system.names.alias"
            type="text"
            value="{{system.names.alias}}"
            placeholder="{{localize 'BITD.Actor.Alias'}}"
          />
        {{/if}}
      </div>
      <div class="character-summary">
        <label for="system.summary">{{localize "BITD.Summary"}}:</label>
        <input
          class="clear-input"
          name="system.summary"
          type="text"
          value="{{system.summary}}"
          placeholder="{{localize 'BITD.Summary'}}"
        />
      </div>
    </div>

  </header>

  {{! Sheet Body }}
  <section class="sheet-body">
    <hr />
    <div class="name-settings flex-centration">
      <label for="system.names.useAlias">{{localize
          "BITD.NPC.UseAsName"
        }}:</label>
      <input
        type="checkbox"
        name="system.names.useAlias"
        {{checked system.names.useAlias}}
      />
    </div>

    {{editor
      enrichedDescription
      target="system.description"
      rollData=rollData
      button=true
      engine="prosemirror"
      editable=editable
      collaborate=true
    }}
  </section>
</form>